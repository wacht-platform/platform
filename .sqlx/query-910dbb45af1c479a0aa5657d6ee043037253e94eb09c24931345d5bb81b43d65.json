  "query": "\n            UPDATE webhook_apps\n            SET signing_secret = $3, updated_at = NOW()\n            WHERE deployment_id = $1 AND name = $2\n            RETURNING \n                deployment_id as \"deployment_id!\",\n                name as \"name!\",\n                description,\n                signing_secret as \"signing_secret!\",\n                is_active as \"is_active!\",\n                created_at as \"created_at!\",\n                updated_at as \"updated_at!\"\n            ",
