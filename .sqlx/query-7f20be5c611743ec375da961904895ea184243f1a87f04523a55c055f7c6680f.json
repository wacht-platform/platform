  "query": "\n            SELECT p.name, ba.status, COALESCE(ba.pulse_usage_disabled, false) AS \"pulse_usage_disabled!\"\n            FROM projects p\n            JOIN billing_accounts ba ON p.billing_account_id = ba.id\n            WHERE p.id = $1 AND p.deleted_at IS NULL\n            ",
