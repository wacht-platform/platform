  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                created_at,\n                updated_at,\n                deployment_id,\n                actor_id,\n                project_id,\n                title,\n                CASE WHEN thread_purpose = 'conversation' THEN 'user_facing' ELSE 'internal' END as \"thread_visibility!\",\n                thread_purpose,\n                responsibility,\n                reusable,\n                accepts_assignments,\n                capability_tags,\n                system_instructions,\n                last_activity_at,\n                completed_at,\n                execution_state,\n                status\n            FROM agent_threads\n            WHERE id = $1 AND deployment_id = $2\n            ",
