{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, deployment_id, thread_id, board_item_id, status, metadata, created_at, updated_at\n            FROM thread_task_graphs\n            WHERE deployment_id = $1\n              AND thread_id = $2\n              AND (($3::bigint IS NULL AND board_item_id IS NULL) OR board_item_id = $3)\n              AND status = $4\n            ORDER BY id DESC\n            LIMIT 1\n            FOR UPDATE\n            ",
