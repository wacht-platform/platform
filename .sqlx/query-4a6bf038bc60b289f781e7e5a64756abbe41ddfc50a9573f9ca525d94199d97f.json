  "query": "\n            SELECT\n                id,\n                deployment_id,\n                policy_id,\n                actor_id,\n                project_id,\n                thread_id,\n                tool_id,\n                granted_by_message_id,\n                grant_scope,\n                status,\n                granted_at,\n                expires_at,\n                consumed_at,\n                consumed_by_run_id,\n                metadata\n            FROM approval_grants\n            WHERE deployment_id = $1\n              AND status = $2\n              AND thread_id = $3\n            ORDER BY granted_at ASC\n            ",
