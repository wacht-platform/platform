  "query": "\n            SELECT e.id, e.url, e.headers, e.timeout_seconds, a.signing_secret\n            FROM webhook_endpoints e\n            JOIN webhook_apps a ON (e.deployment_id = a.deployment_id AND e.app_name = a.name)\n            WHERE e.id = $1 AND e.deployment_id = $2\n            ",
