  "query": "\n                SELECT e.id, e.url, e.max_retries, e.app_name, a.signing_secret, e.deployment_id\n                FROM webhook_endpoints e\n                JOIN webhook_apps a ON (e.deployment_id = a.deployment_id AND e.app_name = a.name)\n                WHERE e.id = $1\n                ",
