  "query": "\n            UPDATE webhook_event_catalogs\n            SET events = $3, updated_at = NOW()\n            WHERE deployment_id = $1 AND slug = $2\n            RETURNING deployment_id as \"deployment_id!\",\n                      slug as \"slug!\",\n                      name as \"name!\",\n                      description,\n                      events as \"events!\",\n                      created_at as \"created_at!\",\n                      updated_at as \"updated_at!\"\n            ",
