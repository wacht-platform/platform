{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT s.id, s.created_at, s.updated_at, s.deleted_at, s.deployment_id, s.name,\n                   s.type as \"segment_type: _\"\n            FROM segments s\n            JOIN workspace_segments ws ON s.id = ws.segment_id\n            WHERE ws.workspace_id = $1\n            ",
