  "query": "\n            SELECT \n                s.id as session_id,\n                si.user_id,\n                si.active_organization_membership_id,\n                si.active_workspace_membership_id\n            FROM sessions s\n            JOIN signins si ON s.active_signin_id = si.id\n            WHERE s.id = $1\n            ",
