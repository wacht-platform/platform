{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                g.id,\n                g.deployment_id,\n                g.app_slug as api_auth_app_slug,\n                g.oauth_client_id,\n                g.resource,\n                g.scopes as \"scopes: serde_json::Value\",\n                g.status,\n                g.granted_at,\n                g.expires_at,\n                g.revoked_at,\n                g.granted_by_user_id,\n                g.created_at,\n                g.updated_at\n            FROM oauth_client_grants g\n            WHERE g.deployment_id = $1\n              AND g.oauth_client_id = $2\n            ORDER BY g.created_at DESC\n            ",
