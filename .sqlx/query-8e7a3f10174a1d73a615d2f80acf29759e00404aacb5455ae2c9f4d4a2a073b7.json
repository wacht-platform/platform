{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT s.id, s.created_at, s.updated_at, s.deleted_at, s.deployment_id, s.name,\n                   s.type as \"segment_type: _\"\n            FROM segments s\n            JOIN organization_segments os ON s.id = os.segment_id\n            WHERE os.organization_id = $1\n            ",
