  "db_name": "PostgreSQL",
  "query": "\n            UPDATE segments\n            SET\n                updated_at = NOW(),\n                name = COALESCE($3, name)\n            WHERE id = $1\n              AND deployment_id = $2\n              AND deleted_at IS NULL\n            RETURNING\n                id,\n                created_at,\n                updated_at,\n                deleted_at,\n                deployment_id,\n                name,\n                type as \"segment_type!\"\n            ",
