  "query": "\n            SELECT e.id, e.url, e.max_retries, a.signing_secret, e.deployment_id\n            FROM webhook_endpoints e\n            JOIN webhook_apps a ON (e.deployment_id = a.deployment_id AND e.app_slug = a.app_slug)\n            WHERE e.id = $1\n            ",
