{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each execution_messages}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{json_string this.content}}"
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}},
    {
      "role": "user",
      "parts": [
        {
          "text": "Generate both an execution summary and working memory items from this conversation.\n\n1. Execution Summary: Summarize ONLY what the assistant did or responded with. Do NOT include what the user said (it's already stored). Be extremely concise - use single words for simple interactions (e.g., \"Greeted.\", \"Acknowledged.\", \"Explained X\").\n\n2. Working Memory: Extract important facts, preferences, identifiers, and context that should be remembered for future interactions. Only add NEW information not already captured in existing memories.\n\nProvide both sections clearly separated."
        }
      ]
    }
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "agent_execution": {
          "type": "STRING",
          "description": "A concise summary of ONLY what the assistant did or said. Never include user messages. Use single words for simple responses like 'Greeted.' or 'Acknowledged.'"
        },
        "working_memory": {
          "type": "ARRAY",
          "items": {
            "type": "STRING",
            "description": "A single working memory item - a fact, preference, identifier, or context detail to remember"
          },
          "description": "Important facts, preferences, identifiers, and context extracted from the execution that should be remembered for future interactions"
        }
      },
      "required": ["agent_execution", "working_memory"]
    },
    "temperature": 0.2,
    "maxOutputTokens": 1000
  }
}