{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      {{#if this.parts}}
      "parts": {{json this.parts}}
      {{else}}
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
      {{/if}}
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "question": {
          "type": "STRING",
          "description": "The specific question to ask the user"
        },
        "context": {
          "type": "STRING",
          "description": "Brief explanation of why this information is needed"
        },
        "suggestions": {
          "type": "ARRAY",
          "description": "Optional suggested values or examples",
          "items": {
            "type": "STRING"
          }
        },
        "validation_hints": {
          "type": "STRING",
          "description": "Optional format requirements or constraints"
        },
        "input_type": {
          "type": "STRING",
          "description": "Type of input: text, number, select, multiselect, boolean, or date",
          "enum": ["text", "number", "select", "multiselect", "boolean", "date"]
        },
        "options": {
          "type": "ARRAY",
          "description": "For select/multiselect types, the list of valid options",
          "items": {
            "type": "STRING"
          }
        },
        "default_value": {
          "type": "STRING",
          "description": "Optional default value for the input"
        },
        "placeholder": {
          "type": "STRING",
          "description": "Optional placeholder text for text/number inputs"
        }
      },
      "required": ["question", "context", "input_type"]
    }
  }
}