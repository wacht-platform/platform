{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      {{#if this.parts}}
      "parts": {{json this.parts}}
      {{else}}
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
      {{/if}}
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "thinkingConfig": {
      "thinkingBudget": 32
    },
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "reasoning_summary": {
          "type": "STRING",
          "description": "Your analytical reasoning process and key insights discovered in this iteration. This will be shown to the user, so follow the CRITICAL COMMUNICATION RULE - never mention tool names or technical implementation details. Describe actions in natural language."
        },
        "needs_more_iteration": {
          "type": "BOOLEAN",
          "description": "Whether you need another iteration to gather more information"
        },
        "context_search_request": {
          "type": "STRING",
          "description": "Specific information needed to enhance your reasoning and provide better strategic guidance",
          "nullable": true
        },
        "requires_user_input": {
          "type": "BOOLEAN",
          "description": "Whether you need direct input, confirmation, or clarification from the user before proceeding"
        },
        "user_input_request": {
          "type": "STRING",
          "description": "Specific question or clarification needed from the user (required if requires_user_input is true)",
          "nullable": true
        },
        "execution_plan": {
          "type": "OBJECT",
          "properties": {
            "analysis": {
              "type": "OBJECT",
              "properties": {
                "understanding": {
                  "type": "STRING",
                  "description": "What you understand the user wants to achieve"
                },
                "approach": {
                  "type": "STRING",
                  "description": "Your recommended approach at a high level"
                },
                "tradeoffs": {
                  "type": "STRING",
                  "description": "Key tradeoffs or considerations in your approach"
                }
              },
              "required": ["understanding", "approach", "tradeoffs"]
            },
            "success_criteria": {
              "type": "STRING",
              "description": "What success looks like for this request"
            }
          },
          "required": ["analysis", "success_criteria"]
        }
      },
      "required": ["reasoning_summary", "needs_more_iteration", "requires_user_input", "execution_plan"]
    },
    "temperature": 0.7,
    "maxOutputTokens": 8192
  }
}
