{
"system_instruction": {
"parts": [
{
"text": "{{system_prompt}}"
}
]
},
"contents": [
{{#each conversation_history}}
{
"role": "{{this.role}}",
{{#if this.parts}}
"parts": {{json this.parts}}
{{else}}
"parts": [
{
"text": "{{this.content}}"
}
]
{{/if}}
}{{#unless @last}},{{/unless}}
{{/each}},
{
"role": "user",
"parts": [
{
"text": "## Deep Reasoning Request\n\n**Problem Statement:**\n{{problem_statement}}\n\n**Context
Summary:**\n{{context_summary}}\n\n**Expected Output Type:** {{expected_output_type}}\n\nPlease analyze this problem
thoroughly. Take your time to think through all aspects."
}
]
}
],
"generationConfig": {
"responseMimeType": "application/json",
"responseSchema": {
"type": "OBJECT",
"properties": {
"analysis": {
"type": "STRING",
"description": "Your detailed analysis and reasoning process"
},
"conclusion": {
"type": "STRING",
"description": "Clear conclusion or recommendation based on your analysis"
},
"next_actions": {
"type": "ARRAY",
"items": {"type": "STRING"},
"description": "Recommended next actions based on this analysis"
},
"confidence": {
"type": "NUMBER",
"description": "Confidence in this analysis (0.0 to 1.0)"
},
"caveats": {
"type": "ARRAY",
"items": {"type": "STRING"},
"description": "Any caveats, uncertainties, or areas needing more investigation"
}
},
"required": ["analysis", "conclusion", "next_actions", "confidence"]
},
"thinkingConfig": {
"thinkingLevel": "high"
}
}
}