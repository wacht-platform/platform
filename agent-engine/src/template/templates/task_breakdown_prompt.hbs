{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      {{#if this.parts}}
      "parts": {{json this.parts}}
      {{else}}
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
      {{/if}}
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "thinkingConfig": {
      "thinkingBudget": 256
    },
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "task_breakdown": {
          "type": "OBJECT",
          "properties": {
            "total_tasks": {
              "type": "INTEGER",
              "description": "Total number of tasks"
            },
            "estimated_duration": {
              "type": "STRING",
              "description": "Rough estimate of execution time"
            },
            "critical_path": {
              "type": "ARRAY",
              "items": {
                "type": "STRING"
              },
              "description": "Task IDs that form the critical path"
            }
          },
          "required": ["total_tasks", "estimated_duration", "critical_path"]
        },
        "tasks": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "id": {
                "type": "STRING",
                "description": "Unique task identifier"
              },
              "name": {
                "type": "STRING",
                "description": "Short descriptive name"
              },
              "description": {
                "type": "STRING",
                "description": "Detailed description of what this task does"
              },
              "dependencies": {
                "type": "ARRAY",
                "items": {
                  "type": "STRING"
                },
                "description": "Task IDs this depends on"
              },
              "success_criteria": {
                "type": "STRING",
                "description": "How to determine task success"
              },
              "error_handling": {
                "type": "STRING",
                "description": "What to do on failure"
              },
              "can_run_parallel": {
                "type": "BOOLEAN",
                "description": "Whether this can run in parallel with siblings"
              }
            },
            "required": ["id", "name", "description", "success_criteria", "error_handling", "can_run_parallel"]
          }
        },
        "execution_notes": {
          "type": "STRING",
          "description": "Any special considerations for execution"
        }
      },
      "required": ["task_breakdown", "tasks", "execution_notes"]
    },
    "temperature": 0.6,
    "maxOutputTokens": 8192
  }
}
