{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      {{#if this.parts}}
      "parts": {{json this.parts}}
      {{else}}
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
      {{/if}}
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "validation_result": {
          "type": "OBJECT",
          "properties": {
            "overall_success": {
              "type": "BOOLEAN",
              "description": "Whether the objectives are sufficiently met"
            },
            "completeness_score": {
              "type": "NUMBER",
              "description": "Percentage of completion (0-100)"
            },
            "achievements": {
              "type": "ARRAY",
              "items": {
                "type": "STRING"
              },
              "description": "What was successfully accomplished"
            },
            "remaining_gaps": {
              "type": "ARRAY",
              "items": {
                "type": "STRING"
              },
              "description": "What remains incomplete (if any)"
            }
          },
          "required": ["overall_success", "completeness_score", "achievements", "remaining_gaps"]
        },
        "next_action": {
          "type": "STRING",
          "enum": ["continue", "complete"],
          "description": "Whether to continue iterating or complete"
        },
        "reasoning": {
          "type": "STRING",
          "description": "Brief explanation of the decision"
        },
        "next_focus": {
          "type": "STRING",
          "description": "If continuing, what to focus on next",
          "nullable": true
        }
      },
      "required": ["validation_result", "next_action", "reasoning"]
    },
    "temperature": 0.6,
    "maxOutputTokens": 2048
  }
}