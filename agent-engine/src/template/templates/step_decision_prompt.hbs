{
"system_instruction": {
"parts": [
{
"text": "{{system_prompt}}"
}
]
},
"contents": [
{{#each conversation_history}}
{
"role": "{{this.role}}",
{{#if this.parts}}
"parts": {{json this.parts}}
{{else}}
"parts": [
{
"text": "[{{relative_time this.timestamp}}] {{this.content}}"
}
]
{{/if}}
}{{#unless @last}},{{/unless}}
{{/each}}
],
"generationConfig": {
"responseMimeType": "application/json",
"responseSchema": {
"type": "OBJECT",
"properties": {
"next_step": {
"type": "STRING",
"enum": [
{{#if is_child_context}}
"gathercontext", "loadmemory", "executeaction", "longthinkandreason", "complete"
{{else}}
"acknowledge", "gathercontext", "loadmemory", "executeaction", "requestuserinput", "longthinkandreason", "complete"
{{/if}}
],
"description": "The next step to execute in the flow"
},
"reasoning": {
"type": "STRING",
"description": "Clear explanation of why this step is the most appropriate next action based on current state and
conversation history"
},
"confidence": {
"type": "NUMBER",
"description": "Confidence level in this decision (0.0 to 1.0)"
},
{{#unless is_child_context}}
"acknowledgment": {
"type": "OBJECT",
"description": "Acknowledgment details (required when next_step is acknowledge)",
"properties": {
"message": {
"type": "STRING",
"description": "The acknowledgment message to send to the user"
},
"further_action_required": {
"type": "BOOLEAN",
"description": "Whether the request requires further processing beyond acknowledgment. MUST be false for greetings,
presence checks, or if your message ends with a question. Only true for explicit action requests."
},
"objective": {
"type": "OBJECT",
"description": "The understood objective from the user's request",
"properties": {
"primary_goal": {
"type": "STRING",
"description": "The main goal to accomplish"
},
"success_criteria": {
"type": "ARRAY",
"items": {
"type": "STRING"
},
"description": "Measurable criteria for successful completion"
},
"constraints": {
"type": "ARRAY",
"items": {
"type": "STRING"
},
"description": "Limitations or requirements to respect"
},
"context_from_history": {
"type": "STRING",
"description": "Relevant context from conversation history that informs this objective"
},
"inferred_intent": {
"type": "STRING",
"description": "The inferred intent behind the user's request"
}
},
"required": ["primary_goal", "success_criteria", "constraints", "context_from_history", "inferred_intent"]
}
},
"required": ["message", "further_action_required", "objective"]
},
{{/unless}}
"actions": {
"type": "ARRAY",
"description": "List of actions to execute in parallel (max 10). Required when next_step is executeaction.",
"items": {
"type": "OBJECT",
"properties": {
"details": {
"type": "OBJECT",
"description": "Action details containing tool information",
"properties": {
"tool_name": {
"type": "STRING",
"description": "The name of the tool to execute"
}
}
},
"purpose": {
"type": "STRING",
"description": "Clear purpose of this action. Include concrete parameter values (IDs, names, dates) when known so parameter generation is deterministic."
},
"context_messages": {
"type": "INTEGER",
"description": "Number of recent conversation messages to include for parameter generation (default: 1). Use purpose
field as primary context."
}
},
"required": ["details", "purpose"]
}
},
"memory_loading_directive": {
"type": "OBJECT",
"description": "MANDATORY when next_step is loadmemory. Directive for loading deeper memories.",
"properties": {
"scope": {
"type": "STRING",
"enum": ["current_session", "cross_session", "universal"],
"description": "Memory scope: current_session (this chat), cross_session (agent patterns), universal (both)"
},
"focus": {
"type": "STRING",
"description": "Semantic search query for finding relevant memories, or empty for high-value memories"
},
"categories": {
"type": "ARRAY",
"items": {"type": "STRING"},
"description": "Memory categories to search: procedural (how-to), semantic (facts), episodic (events), working (state)"
},
"depth": {
"type": "STRING",
"enum": ["shallow", "moderate", "deep"],
"description": "How deep to search for memories"
}
},
"required": ["scope", "focus"]
},
"context_gathering_directive": {
"type": "OBJECT",
"description": "MANDATORY when next_step is gathercontext. Mode-based context retrieval directive.",
"properties": {
"mode": {
"type": "STRING",
"enum": ["search_web", "search_local_knowledge"],
"description": "Context gathering mode. Use search_local_knowledge for local KB retrieval."
},
"query": {
"type": "STRING",
"description": "Search query to run in the selected mode."
},
"target_output": {
"type": "STRING",
"description": "Exact output expected from gathercontext (what the agent should receive back)."
},
"local_knowledge": {
"type": "OBJECT",
"description": "Required when mode is search_local_knowledge.",
"properties": {
"search_type": {
"type": "STRING",
"enum": ["semantic", "keyword"],
"description": "Retrieval strategy for local KB search."
},
"knowledge_base_ids": {
"type": "ARRAY",
"items": {"type": "STRING"},
"description": "Optional KB IDs to scope search. If omitted, all available KBs are searched.",
"nullable": true
},
"max_results": {
"type": "INTEGER",
"description": "Max retrieved matches before post-processing (default 12).",
"nullable": true
},
"include_associated_chunks": {
"type": "BOOLEAN",
"description": "Whether to load additional related chunks for top documents.",
"nullable": true
},
"max_associated_chunks_per_document": {
"type": "INTEGER",
"description": "Additional chunks to load per top document when include_associated_chunks=true.",
"nullable": true
},
"max_query_rewrites": {
"type": "INTEGER",
"description": "How many retrieval rewrite passes to run (default 3).",
"nullable": true
}
},
"required": ["search_type"],
"nullable": true
}
},
"required": ["mode", "query", "target_output"]
},
"completion_message": {
"type": "STRING",
"description": "REQUIRED when next_step is 'complete'. A user-facing summary of what was accomplished, findings, or
final response.",
"nullable": true
}
},
"required": ["next_step", "reasoning", "confidence"]
},
"thinkingConfig": {
"thinkingLevel": "low"
},
}
}
