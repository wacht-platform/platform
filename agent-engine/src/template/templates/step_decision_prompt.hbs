{
"system_instruction": {
"parts": [
{
"text": "{{system_prompt}}"
}
]
},
"contents": [
{{#each conversation_history}}
{
"role": "{{this.role}}",
{{#if this.parts}}
"parts": {{json this.parts}}
{{else}}
"parts": [
{
"text": "[{{relative_time this.timestamp}}] {{this.content}}"
}
]
{{/if}}
}{{#unless @last}},{{/unless}}
{{/each}}
],
"generationConfig": {
"responseMimeType": "application/json",
"responseSchema": {
"type": "OBJECT",
"properties": {
"next_step": {
"type": "STRING",
"enum": ["acknowledge", "gathercontext", "loadmemory", "executeaction", "requestuserinput", "longthinkandreason",
"complete"],
"description": "The next step to execute in the flow"
},
"reasoning": {
"type": "STRING",
"description": "Clear explanation of why this step is the most appropriate next action based on current state and
conversation history"
},
"confidence": {
"type": "NUMBER",
"description": "Confidence level in this decision (0.0 to 1.0)"
},
"acknowledgment": {
"type": "OBJECT",
"description": "Acknowledgment details (required when next_step is acknowledge)",
"properties": {
"message": {
"type": "STRING",
"description": "The acknowledgment message to send to the user"
},
"further_action_required": {
"type": "BOOLEAN",
"description": "Whether the request requires further processing beyond acknowledgment. MUST be false for greetings,
presence checks, or if your message ends with a question. Only true for explicit action requests."
},
"objective": {
"type": "OBJECT",
"description": "The understood objective from the user's request",
"properties": {
"primary_goal": {
"type": "STRING",
"description": "The main goal to accomplish"
},
"success_criteria": {
"type": "ARRAY",
"items": {
"type": "STRING"
},
"description": "Measurable criteria for successful completion"
},
"constraints": {
"type": "ARRAY",
"items": {
"type": "STRING"
},
"description": "Limitations or requirements to respect"
},
"context_from_history": {
"type": "STRING",
"description": "Relevant context from conversation history that informs this objective"
},
"inferred_intent": {
"type": "STRING",
"description": "The inferred intent behind the user's request"
}
},
"required": ["primary_goal", "success_criteria", "constraints", "context_from_history", "inferred_intent"]
}
},
"required": ["message", "further_action_required", "objective"]
},
"actions": {
"type": "ARRAY",
"description": "List of actions to execute in parallel (max 10). Required when next_step is executeaction.",
"items": {
"type": "OBJECT",
"properties": {
"type": {
"type": "STRING",
"enum": ["tool_call", "workflow_call"],
"description": "The type of action to execute"
},
"details": {
"type": "OBJECT",
"description": "Action details containing tool/workflow information",
"properties": {
"tool_name": {
"type": "STRING",
"description": "The name of the tool to execute (required for tool_call)"
},
"workflow_name": {
"type": "STRING",
"description": "The name of the workflow to execute (required for workflow_call)"
}
}
},
"purpose": {
"type": "STRING",
"description": "Clear purpose of this action. Be specific about the intent (e.g. 'asking a question'). You MUST verbally
account for all important configuration parameters of the selected tool here to guide the parameter generator."
},
"context_messages": {
"type": "INTEGER",
"description": "Number of recent conversation messages to include for parameter generation (default: 1). Use purpose
field as primary context."
},
"clear_actionable_id": {
"type": "STRING",
"description": "If this tool call fulfills a pending actionable, provide the actionable ID here. It will be
automatically cleared after the tool executes. Get the ID from the actionables list (e.g., 'notify_1736...')."
}
},
"required": ["type", "details", "purpose"]
}
},
"memory_loading_directive": {
"type": "OBJECT",
"description": "MANDATORY when next_step is loadmemory. Directive for loading deeper memories.",
"properties": {
"scope": {
"type": "STRING",
"enum": ["current_session", "cross_session", "universal"],
"description": "Memory scope: current_session (this chat), cross_session (agent patterns), universal (both)"
},
"focus": {
"type": "STRING",
"description": "Semantic search query for finding relevant memories, or empty for high-value memories"
},
"categories": {
"type": "ARRAY",
"items": {"type": "STRING"},
"description": "Memory categories to search: procedural (how-to), semantic (facts), episodic (events), working (state)"
},
"depth": {
"type": "STRING",
"enum": ["shallow", "moderate", "deep"],
"description": "How deep to search for memories"
}
},
"required": ["scope", "focus"]
},
"context_gathering_directive": {
"type": "OBJECT",
"description": "MANDATORY when next_step is gathercontext. Structured directive for intelligent context gathering.",
"properties": {
"pattern": {
"type": "STRING",
"enum": ["troubleshooting", "implementation", "analysis", "historical", "exploration", "verification"],
"description": "The search pattern based on user's request type"
},
"objective": {
"type": "STRING",
"description": "Specific goal for this context gathering (e.g., 'Find authentication errors in logs', 'Gather user
management documentation')"
},
"focus_areas": {
"type": "ARRAY",
"items": {"type": "STRING"},
"description": "Key areas to prioritize (e.g., ['error logs', 'recent changes', 'configuration'])",
"nullable": true
},
"expected_depth": {
"type": "STRING",
"enum": ["shallow", "moderate", "deep"],
"description": "How thorough the search should be based on request complexity",
"nullable": true
}
},
"required": ["pattern", "objective"]
},
"completion_message": {
"type": "STRING",
"description": "REQUIRED when next_step is 'complete'. A user-facing summary of what was accomplished, findings, or
final response.",
"nullable": true
},
"deep_reasoning_directive": {
"type": "OBJECT",
"description": "REQUIRED when next_step is 'longthinkandreason'. Provides context for deep reasoning.",
"properties": {
"problem_statement": {
"type": "STRING",
"description": "Clear statement of the complex problem to reason about"
},
"context_summary": {
"type": "STRING",
"description": "Summary of all relevant context gathered so far"
},
"expected_output_type": {
"type": "STRING",
"enum": ["analysis", "decision", "plan", "synthesis", "debugging"],
"description": "Type of reasoning output expected"
}
},
"required": ["problem_statement", "context_summary", "expected_output_type"],
"nullable": true
}
},
"required": ["next_step", "reasoning", "confidence"]
},
"thinkingConfig": {
"thinkingLevel": "low"
},
}
}