{
"system_instruction": {
"parts": [
{
"text": "{{system_prompt}}"
}
]
},
"contents": [
{{#each conversation_history}}
{
"role": "{{this.role}}",
{{#if this.parts}}
"parts": {{json this.parts}}
{{else}}
"parts": [
{
"text": "{{this.content}}"
}
]
{{/if}}
}{{#unless @last}},{{/unless}}
{{/each}}
{{#if conversation_history}},{{/if}}
{
"role": "user",
"parts": [
{
"text": "Generate parameters for tool '{{tool_name}}' with purpose: {{action_purpose}}"
}
]
}
],
"generationConfig": {

"responseMimeType": "application/json",
"responseSchema": {
"type": "OBJECT",
"properties": {
"parameter_generation": {
"type": "OBJECT",
"properties": {
"can_generate": {
"type": "BOOLEAN",
"description": "Whether all required parameters can be generated"
},
"missing_information": {
"type": "ARRAY",
"items": {
"type": "STRING"
},
"description": "List of missing information preventing parameter generation"
},
"parameters": {{json parameter_schema}}
},
"required": ["can_generate", "missing_information", "parameters"]
},
"execution_notes": {
"type": "STRING",
"description": "Any notes about the parameter generation"
}
},
"required": ["parameter_generation", "execution_notes"]
},
"temperature": 0.3,
"maxOutputTokens": 8192
}
}