{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {
      "role": "user",
      "parts": [
        {
          "text": "I need you to evaluate whether a workflow should be triggered based on the current context.\n\n## Trigger Condition\nThe workflow should trigger when: {{trigger_condition}}\n\n{{#if trigger_description}}## Trigger Description\n{{trigger_description}}\n{{/if}}\n\n## Current Context\nHere is the current state and available data:\n{{json_string workflow_state}}\n\nAnalyze whether the trigger condition is satisfied by the current context. Be thorough and consider all requirements expressed in the trigger condition."
        }
      ]
    }
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "reasoning": {
          "type": "STRING",
          "description": "Detailed explanation of your evaluation"
        },
        "should_trigger": {
          "type": "BOOLEAN",
          "description": "Whether the workflow should be triggered"
        },
        "confidence": {
          "type": "NUMBER",
          "description": "Confidence score between 0.0 and 1.0"
        },
        "missing_requirements": {
          "type": "ARRAY",
          "description": "List of requirements that are not met",
          "items": {
            "type": "STRING"
          },
          "nullable": true
        }
      },
      "required": ["reasoning", "should_trigger", "confidence"]
    },
    "temperature": 0.3,
    "maxOutputTokens": 2048
  }
}