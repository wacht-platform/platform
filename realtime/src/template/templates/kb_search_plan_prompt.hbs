{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    },
    {{/each}}
    {
      "role": "model",
      "parts": [
        {
          "text": "Based on the conversation above, I need to search for information to build my internal context.\n\nSearch Context:\n- Search Query: {{search_query}}\n- Search Scope: {{search_scope}}\n- Available Knowledge Bases:\n{{#each available_knowledge_bases}}  - ID: {{this.id}}, Name: \"{{this.name}}\"{{#if this.description}}, Description: \"{{this.description}}\"{{/if}}\n{{/each}}\nSearch Filters:\n- Max Results: {{search_filters.max_results}}\n- Search Mode: {{search_filters.search_mode}}\n{{#if search_filters.boost_keywords}}- Boost Keywords: {{#each search_filters.boost_keywords}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}\n\nPlease create a search plan for finding the relevant information in the knowledge base."
        }
      ]
    }
  ],
  "generationConfig": {
    "temperature": 0.4,
    "maxOutputTokens": 2048,
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "search_approach": {
          "type": "STRING",
          "description": "Overall strategy description for how you plan to search"
        },
        "reasoning": {
          "type": "STRING",
          "description": "Why this approach will work for building your internal context"
        },
        "strategy": {
          "type": "OBJECT",
          "description": "The search strategy to execute",
          "properties": {
            "strategy_type": {
              "type": "STRING",
              "enum": ["keyword_search", "semantic_search"],
              "description": "Type of search: keyword_search or semantic_search"
            },
            "description": {
              "type": "STRING",
              "description": "What this strategy will do"
            },
            "parameters": {
              "type": "OBJECT",
              "description": "Search parameters for this strategy",
              "properties": {
                "knowledge_base_id": {
                  "type": "STRING",
                  "nullable": true,
                  "description": "Specific KB ID or null for all"
                },
                "keywords": {
                  "type": "ARRAY",
                  "nullable": true,
                  "description": "Array of search keywords (for keyword_search)",
                  "items": {
                    "type": "STRING"
                  }
                },
                "search_query": {
                  "type": "STRING",
                  "nullable": true,
                  "description": "Natural language query (for semantic_search)"
                },
                "similarity_threshold": {
                  "type": "NUMBER",
                  "nullable": true,
                  "description": "Minimum similarity score (0.0-1.0)"
                },
                "max_chunks": {
                  "type": "INTEGER",
                  "nullable": true,
                  "description": "Maximum number of chunks to return"
                },
                "keyword_boost": {
                  "type": "ARRAY",
                  "nullable": true,
                  "description": "Keywords to boost in scoring",
                  "items": {
                    "type": "STRING"
                  }
                }
              }
            }
          },
          "required": ["strategy_type", "description", "parameters"]
        }
      },
      "required": ["search_approach", "reasoning", "strategy"]
    }
  }
}
