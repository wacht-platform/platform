{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "next_step": {
          "type": "STRING",
          "enum": ["gather_context", "breakdown_tasks", "execute_tasks", "validate_progress", "deliver_response", "request_user_input", "handle_error", "complete", "direct_execution"],
          "description": "The next step to execute in the flow"
        },
        "reasoning": {
          "type": "STRING",
          "description": "Clear explanation of why this step is the most appropriate next action based on current state and conversation history"
        },
        "confidence": {
          "type": "NUMBER",
          "description": "Confidence level in this decision (0.0 to 1.0)"
        },
        "direct_execution_params": {
          "type": "OBJECT",
          "description": "Information for direct tool/workflows execution (required when next_step is direct_execution)",
          "properties": {
            "execution_type": {
              "type": "STRING",
              "enum": ["tool", "workflow"]
            },
            "resource_name": {
              "type": "STRING",
              "description": "The exact name of the tool or workflow to execute"
            }
          },
          "required": ["resource_name", "execution_type"]
        }
      },
      "required": ["next_step", "reasoning", "confidence"]
    }
  }
}
