{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "ready_to_execute": {
          "type": "BOOLEAN",
          "description": "Whether the workflow can execute successfully with current inputs"
        },
        "missing_requirements": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          },
          "description": "List of specific missing data or conditions needed for execution"
        },
        "validation_message": {
          "type": "STRING",
          "description": "Clear message about validation status and what was found"
        }
      },
      "required": ["ready_to_execute", "missing_requirements", "validation_message"]
    },
    "temperature": 0.3,
    "maxOutputTokens": 2048
  }
}
