{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "[{{relative_time this.timestamp}}] {{this.content}}"
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "thinkingConfig": {
      "thinkingBudget": 1024
    },
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "strategic_synthesis": {
          "type": "STRING",
          "description": "Your synthesis of how gathered context enhances understanding and informs strategic decisions"
        },
        "context_insights": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          },
          "description": "Key strategic insights and implications derived from the gathered context"
        },
        "refined_strategy": {
          "type": "OBJECT",
          "properties": {
            "enhanced_approach": {
              "type": "STRING",
              "description": "Context-informed strategic approach with reasoning for why this path is optimal"
            },
            "strategic_priorities": {
              "type": "ARRAY",
              "items": {
                "type": "STRING"
              },
              "description": "Key strategic priorities and sequencing based on contextual insights"
            },
            "success_framework": {
              "type": "STRING",
              "description": "Context-informed criteria for measuring strategic success and value delivery"
            },
            "risk_considerations": {
              "type": "ARRAY",
              "items": {
                "type": "STRING"
              },
              "description": "Strategic risks and mitigation approaches informed by gathered context"
            }
          },
          "required": ["enhanced_approach", "strategic_priorities", "success_framework", "risk_considerations"]
        },
        "needs_more_context": {
          "type": "BOOLEAN",
          "description": "Whether additional context is needed before proceeding"
        },
        "strategic_context_request": {
          "type": "STRING",
          "description": "Specific information needed to further enhance strategic reasoning and guidance quality",
          "nullable": true
        },
        "requires_user_input": {
          "type": "BOOLEAN",
          "description": "Whether you need direct input, confirmation, or clarification from the user before proceeding"
        },
        "user_input_request": {
          "type": "STRING",
          "description": "Specific question or clarification needed from the user (required if requires_user_input is true)",
          "nullable": true
        },
        "strategic_readiness": {
          "type": "BOOLEAN",
          "description": "Whether the strategic analysis and guidance are sufficiently developed for implementation planning"
        }
      },
      "required": ["strategic_synthesis", "context_insights", "refined_strategy", "needs_more_context", "requires_user_input", "strategic_readiness"]
    },
    "temperature": 0.6,
    "maxOutputTokens": 16384
  }
}
