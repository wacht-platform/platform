{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "message": {
            "type": "STRING",
            "description": "A natural, conversational response that shows understanding of the user's request and its context. Be specific and reference details from their message."
        },
        "further_action_required": {
            "type": "BOOLEAN",
            "description": "True if you need to use tools/workflows/searches to fulfill the request. False if you're asking for clarification, having a conversation, or the request is already complete."
        },
        "reasoning": {
            "type": "STRING",
            "description": "Your thought process for the decision, including: what you understood from the request, relevant context from the conversation history, and why you chose to proceed or ask for clarification."
        },
        "objective": {
            "type": "OBJECT",
            "description": "The extracted objective from this conversation flow",
            "properties": {
                "primary_goal": {
                    "type": "STRING",
                    "description": "The main objective the user is trying to achieve, derived from current message and recent conversation history"
                },
                "success_criteria": {
                    "type": "ARRAY",
                    "description": "Specific, measurable criteria that would indicate successful completion of the objective",
                    "items": {
                        "type": "STRING"
                    }
                },
                "constraints": {
                    "type": "ARRAY",
                    "description": "Any limitations, requirements, or boundaries mentioned or implied",
                    "items": {
                        "type": "STRING"
                    }
                },
                "context_from_history": {
                    "type": "STRING",
                    "description": "Relevant context extracted from conversation history that informs this objective"
                },
                "inferred_intent": {
                    "type": "STRING",
                    "description": "The deeper intent behind the request - what they're really trying to accomplish"
                }
            },
            "required": ["primary_goal", "success_criteria", "constraints", "context_from_history", "inferred_intent"]
        },
        "conversation_insights": {
            "type": "OBJECT",
            "description": "Insights derived from analyzing the conversation patterns",
            "properties": {
                "is_continuation": {
                    "type": "BOOLEAN",
                    "description": "Whether this is continuing a previous line of discussion or task"
                },
                "topic_evolution": {
                    "type": "STRING",
                    "description": "How the topic has evolved from previous messages"
                },
                "user_preferences": {
                    "type": "ARRAY",
                    "description": "Detected preferences in communication style, approach, or solutions",
                    "items": {
                        "type": "STRING"
                    }
                },
                "relevant_past_outcomes": {
                    "type": "ARRAY",
                    "description": "Previous attempts or outcomes that might inform current approach",
                    "items": {
                        "type": "STRING"
                    }
                }
            },
            "required": ["is_continuation", "topic_evolution", "user_preferences", "relevant_past_outcomes"]
        }
      },
      "required": ["message", "further_action_required", "reasoning", "objective", "conversation_insights"]
    },
    "temperature": 0.8,
    "maxOutputTokens": 2048
  }
}
