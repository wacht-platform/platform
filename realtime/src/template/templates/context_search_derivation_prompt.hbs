{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    },
    {{/each}}
    {
      "role": "model",
      "parts": [
        {
          "text": "Based on the conversation history and current objective, determine what information you need to search for to build your internal context.\n\nCurrent Objective: {{current_objective}}\n\nCRITICAL REMINDERS:\n- NEVER copy phrases from the objective into your search_query\n- If objective mentions 'summary of all documents about X and Y', search for 'X' first, then 'Y'\n- Use simple, focused queries (2-6 words)\n- Avoid meta-terms like 'summary', 'documents', 'all', 'related to'\n\n{{#if has_previous_searches}}IMPORTANT: You have already performed {{previous_search_count}} search(es). Check if the previous searches have found the information needed. If so, return search_scope: \"gathered_context\" to stop searching and avoid redundant searches.{{/if}}\n\nAnalyze the conversation and decide:\n1. What specific information you need to gather\n2. Which search scope would be most appropriate (including \"gathered_context\" if you already have enough information)\n3. What search parameters would yield the best results\n\nRemember: This search is for YOUR internal context building, not directly shown to the user."
        }
      ]
    }
  ],
  "generationConfig": {
    "temperature": 0.3,
    "maxOutputTokens": 2048,
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "search_query": {
          "type": "STRING",
          "description": "CRITICAL: Use 2-6 focused keywords only. NEVER use 'summary of' or 'all documents related to'. For compound requests like 'X and Y', search for 'X' in one iteration and 'Y' in another. DO NOT copy text from the objective."
        },
        "search_scope": {
          "type": "STRING",
          "enum": ["knowledge_base", "experience", "universal", "list_knowledge_base_documents", "read_knowledge_base_documents", "conversations", "gathered_context"],
          "description": "The scope of search: knowledge_base (search KB content), experience (search memories), universal (search all), list_knowledge_base_documents (list available docs), read_knowledge_base_documents (read specific docs), conversations (search recent raw conversations), gathered_context (stop gathering, sufficient context)"
        },
        "filters": {
          "type": "OBJECT",
          "properties": {
            "max_results": {
              "type": "INTEGER",
              "description": "Maximum number of results to return"
            },
            "boost_keywords": {
              "type": "ARRAY",
              "nullable": true,
              "items": {
                "type": "STRING"
              },
              "description": "Optional 1-3 keywords MAX to boost. Do NOT repeat terms already in search_query. Leave empty if not needed."
            },
            "time_range": {
              "type": "STRING",
              "nullable": true,
              "description": "Time constraint like 'last_hour', 'today', 'last_week', 'last_month', 'last_year'"
            },
            "search_mode": {
              "type": "STRING",
              "enum": ["semantic", "keyword", "hybrid"],
              "description": "Search mode: semantic (meaning-based), keyword (exact match), hybrid (combined)"
            },
            "knowledge_base_ids": {
              "type": "ARRAY",
              "nullable": true,
              "items": {
                "type": "STRING"
              },
              "description": "List of specific knowledge base IDs to search in, or null to search all"
            }
          },
          "required": ["max_results", "search_mode"]
        },
        "list_documents_params": {
          "type": "OBJECT",
          "nullable": true,
          "description": "Parameters for listing knowledge base documents (only when search_scope is list_knowledge_base_documents)",
          "properties": {
            "knowledge_base_ids": {
              "type": "ARRAY",
              "nullable": true,
              "description": "Array of KB IDs to list documents from, or null to list from all agent's KBs",
              "items": {
                "type": "STRING"
              }
            },
            "keyword_filter": {
              "type": "STRING",
              "nullable": true,
              "description": "Optional keyword to filter document titles"
            },
            "page": {
              "type": "INTEGER",
              "description": "Page number to fetch (starts from 1). Always start with page 1."
            },
            "limit": {
              "type": "INTEGER",
              "description": "Number of documents per page. Always use 100 as the limit."
            }
          },
          "required": ["page", "limit"]
        },
        "read_document_params": {
          "type": "OBJECT",
          "nullable": true,
          "description": "Parameters for reading document chunks (only when search_scope is read_knowledge_base_documents)",
          "properties": {
            "document_id": {
              "type": "STRING",
              "description": "The ID of the document to read chunks from"
            },
            "chunk_range": {
              "type": "OBJECT",
              "nullable": true,
              "description": "Specific range of chunks to read",
              "properties": {
                "start": {
                  "type": "INTEGER",
                  "description": "Starting chunk index (inclusive)"
                },
                "end": {
                  "type": "INTEGER",
                  "description": "Ending chunk index (inclusive)"
                }
              },
              "required": ["start", "end"]
            },
            "keywords": {
              "type": "ARRAY",
              "nullable": true,
              "description": "Keywords to search for within chunks",
              "items": {
                "type": "STRING"
              }
            },
            "limit": {
              "type": "INTEGER",
              "nullable": true,
              "description": "Maximum number of chunks to return (default: 10)"
            }
          },
          "required": ["document_id"]
        }
      },
      "required": ["search_query", "search_scope", "filters"]
    }
  }
}
