{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "search_query": {
          "type": "STRING",
          "description": "The optimized search query derived from conversation context"
        },
        "search_scope": {
          "type": "STRING",
          "enum": ["knowledge_base", "experience", "universal"],
          "description": "Where to search for information"
        },
        "search_rationale": {
          "type": "STRING",
          "description": "Explanation of why this query and scope were chosen"
        },
        "filters": {
          "type": "OBJECT",
          "properties": {
            "max_results": {
              "type": "INTEGER",
              "description": "Maximum number of results to return (10-50)"
            },
            "min_relevance": {
              "type": "NUMBER",
              "description": "Minimum relevance score (0.0-1.0)"
            },
            "boost_keywords": {
              "type": "ARRAY",
              "items": {
                "type": "STRING"
              },
              "description": "Important keywords to boost in search results",
              "nullable": true
            },
            "time_range": {
              "type": "STRING",
              "description": "Time constraint like 'last_week', 'last_month', 'last_year'",
              "nullable": true
            },
            "search_mode": {
              "type": "STRING",
              "enum": ["semantic", "keyword", "hybrid"],
              "description": "Search mode to use"
            }
          },
          "required": ["max_results", "min_relevance", "search_mode"]
        },
        "alternative_queries": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          },
          "description": "Alternative search queries if primary yields no results"
        }
      },
      "required": ["search_query", "search_scope", "search_rationale", "filters", "alternative_queries"]
    },
    "temperature": 0.3,
    "maxOutputTokens": 2048
  }
}