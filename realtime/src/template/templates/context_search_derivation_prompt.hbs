{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    },
    {{/each}}
    {
      "role": "model",
      "parts": [
        {
          "text": "Based on the conversation history and current objective, determine what information you need to search for to build your internal context.\n\nCurrent Objective: {{current_objective}}\n\nCRITICAL REMINDERS:\n- NEVER copy phrases from the objective into your search_query\n- If objective mentions 'summary of all documents about X and Y', search for 'X' first, then 'Y'\n- Use simple, focused queries (2-6 words)\n- Avoid meta-terms like 'summary', 'documents', 'all', 'related to'\n\n{{#if has_previous_searches}}IMPORTANT: You have already performed {{previous_search_count}} search(es). Check if the previous searches have found the information needed. If so, return search_scope: \"gathered_context\" to stop searching and avoid redundant searches.{{/if}}\n\nAnalyze the conversation and decide:\n1. What specific information you need to gather\n2. Which search scope would be most appropriate (including \"gathered_context\" if you already have enough information)\n3. What search parameters would yield the best results\n\nRemember: This search is for YOUR internal context building, not directly shown to the user."
        }
      ]
    }
  ],
  "generationConfig": {
    "temperature": 0.3,
    "maxOutputTokens": 2048,
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "search_query": {
          "type": "STRING",
          "description": "CRITICAL: Use 2-6 focused keywords only. NEVER use 'summary of' or 'all documents related to'. For compound requests like 'X and Y', search for 'X' in one iteration and 'Y' in another. DO NOT copy text from the objective."
        },
        "next_action": {
          "type": "STRING",
          "enum": ["knowledge_base", "experience", "universal", "list_knowledge_base_documents", "read_knowledge_base_documents", "conversations", "complete"],
          "description": "The next action to take: knowledge_base (search KB content), experience (search memories), universal (search all), list_knowledge_base_documents (list available docs), read_knowledge_base_documents (read specific docs), conversations (search recent raw conversations), complete (objective accomplished, return control to step decision)"
        },
        "filters": {
          "type": "OBJECT",
          "properties": {
            "max_results": {
              "type": "INTEGER",
              "description": "Maximum number of results to return"
            },
            "boost_keywords": {
              "type": "ARRAY",
              "nullable": true,
              "items": {
                "type": "STRING"
              },
              "description": "Optional 1-3 keywords MAX to boost. Do NOT repeat terms already in search_query. Leave empty if not needed."
            },
            "time_range": {
              "type": "STRING",
              "nullable": true,
              "description": "Time constraint like 'last_hour', 'today', 'last_week', 'last_month', 'last_year'"
            },
            "search_mode": {
              "type": "STRING",
              "enum": ["semantic", "keyword", "hybrid"],
              "description": "Search mode: semantic (meaning-based), keyword (exact match), hybrid (combined)"
            },
            "knowledge_base_ids": {
              "type": "ARRAY",
              "nullable": true,
              "items": {
                "type": "STRING"
              },
              "description": "List of specific knowledge base IDs to search in, or null to search all"
            }
          },
          "required": ["max_results", "search_mode"]
        },
        "list_documents_params": {
          "type": "OBJECT",
          "nullable": true,
          "description": "Parameters for listing knowledge base documents (only when next_action is list_knowledge_base_documents)",
          "properties": {
            "knowledge_base_ids": {
              "type": "ARRAY",
              "nullable": true,
              "description": "Array of KB IDs to list documents from, or null to list from all agent's KBs",
              "items": {
                "type": "STRING"
              }
            },
            "keyword_filter": {
              "type": "STRING",
              "nullable": true,
              "description": "Optional keyword to filter document titles"
            },
            "page": {
              "type": "INTEGER",
              "description": "Page number to fetch (starts from 1). Always start with page 1."
            },
            "limit": {
              "type": "INTEGER",
              "description": "Number of documents per page. Always use 100 as the limit."
            }
          },
          "required": ["page", "limit"]
        },
        "read_document_params": {
          "type": "OBJECT",
          "nullable": true,
          "description": "REQUIRED when next_action is read_knowledge_base_documents. MUST contain valid document_id obtained from list_knowledge_base_documents. NEVER use read_knowledge_base_documents action without this parameter.",
          "properties": {
            "document_id": {
              "type": "STRING",
              "description": "MANDATORY: The ID of the document to read chunks from. Must be a valid document_id from previous list_knowledge_base_documents search."
            },
            "chunk_range": {
              "type": "OBJECT",
              "nullable": true,
              "description": "Specific range of chunks to read",
              "properties": {
                "start": {
                  "type": "INTEGER",
                  "description": "Starting chunk index (inclusive)"
                },
                "end": {
                  "type": "INTEGER",
                  "description": "Ending chunk index (inclusive)"
                }
              },
              "required": ["start", "end"]
            },
            "keywords": {
              "type": "ARRAY",
              "nullable": true,
              "description": "Keywords to search for within chunks",
              "items": {
                "type": "STRING"
              }
            },
            "limit": {
              "type": "INTEGER",
              "nullable": true,
              "description": "Maximum number of chunks to return (default: 10)"
            }
          },
          "required": ["document_id"]
        },
        "reasoning": {
          "type": "STRING",
          "description": "Explain your decision: Why this search strategy? What information are you looking for? If using gathered_context, explain what you've found and why it's sufficient. If continuing, explain what specific gaps you're trying to fill."
        },
        "convergence_analysis": {
          "type": "OBJECT",
          "nullable": true,
          "description": "Analysis of search progress and loop detection (included when progress data is available)",
          "properties": {
            "detected_patterns": {
              "type": "ARRAY",
              "items": {
                "type": "STRING"
              },
              "description": "List of any problematic patterns detected (query repetition, diminishing returns, etc.)"
            },
            "progress_assessment": {
              "type": "STRING",
              "enum": ["excellent", "good", "declining", "poor", "exhausted"],
              "description": "Assessment of current search progress effectiveness"
            },
            "should_continue": {
              "type": "BOOLEAN",
              "description": "Based on progress analysis, whether searching should continue"
            },
            "confidence_in_decision": {
              "type": "NUMBER",
              "description": "Confidence level (0.0-1.0) in the decision to continue or stop"
            }
          },
          "required": ["progress_assessment", "should_continue", "confidence_in_decision"]
        }
      },
      "required": ["search_query", "next_action", "filters", "reasoning"]
    }
  }
}
