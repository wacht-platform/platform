## Instructions
1. Verify if the task objective was fully met
2. Determine if any follow-up tasks are needed
3. **CRITICAL: The `message` field is what the user sees - make it friendly and conversational**
4. IMPORTANT: Look at the original user request and extract ALL relevant information from the results that answers their question
   - If they asked about location, include location details (city, country, etc.)
   - If they asked about IP, include the IP address
   - If they asked about both, include both
5. The `message` field should directly answer what the user asked for, not just what the task objective states
6. **DO NOT include technical jargon in the `message` field** such as:
   - "Task execution completed"
   - "Objective met"
   - "Completion percentage"
   - "Follow-up tasks"
   - Any mention of system internals or task IDs
7. The `message` field should be natural conversation, as if talking to a friend
8. Other fields (objective_met, completion_percentage, etc.) are for internal use only

## Response Format:
Your response must be an XML document (NOT an XSD schema). Output the verification following the structure shown in the examples below.

## Schema Reference (DO NOT OUTPUT THIS - FOR REFERENCE ONLY):
The following XSD schema shows the structure for reference:

```xml
<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="verification">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="message" type="xs:string"/>
        <xs:element name="objective_met" type="xs:boolean"/>
        <xs:element name="completion_percentage">
          <xs:simpleType>
            <xs:restriction base="xs:integer">
              <xs:minInclusive value="0"/>
              <xs:maxInclusive value="100"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:element name="results_summary" type="xs:string"/>
        <xs:element name="gaps" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
        <xs:element name="citations" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="memory_reference" minOccurs="0" maxOccurs="unbounded">
                <xs:complexType>
                  <xs:simpleContent>
                    <xs:extension base="xs:string">
                      <xs:attribute name="id" type="xs:string" use="required"/>
                      <xs:attribute name="relevance" type="xs:string" use="required"/>
                      <xs:attribute name="usefulness" type="xs:string" use="required"/>
                      <xs:attribute name="confidence" type="xs:string" use="required"/>
                      <xs:attribute name="usage_type" type="xs:string" use="required"/>
                    </xs:extension>
                  </xs:simpleContent>
                </xs:complexType>
              </xs:element>
              <xs:element name="conversation_reference" minOccurs="0" maxOccurs="unbounded">
                <xs:complexType>
                  <xs:simpleContent>
                    <xs:extension base="xs:string">
                      <xs:attribute name="id" type="xs:string" use="required"/>
                      <xs:attribute name="relevance" type="xs:string" use="required"/>
                      <xs:attribute name="usefulness" type="xs:string" use="required"/>
                      <xs:attribute name="confidence" type="xs:string" use="required"/>
                      <xs:attribute name="usage_type" type="xs:string" use="required"/>
                    </xs:extension>
                  </xs:simpleContent>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="follow_up_tasks" minOccurs="0" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="id" type="xs:string"/>
              <xs:element name="objective" type="xs:string"/>
              <xs:element name="description" type="xs:string"/>
              <xs:element name="priority" type="xs:string"/>
              <xs:element name="dependencies" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="memory_updates" minOccurs="0" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="content" type="xs:string"/>
              <xs:element name="type">
                <xs:simpleType>
                  <xs:restriction base="xs:string">
                    <xs:enumeration value="episodic"/>
                    <xs:enumeration value="semantic"/>
                    <xs:enumeration value="procedural"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
              <xs:element name="importance">
                <xs:simpleType>
                  <xs:restriction base="xs:decimal">
                    <xs:minInclusive value="0.0"/>
                    <xs:maxInclusive value="1.0"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
```

