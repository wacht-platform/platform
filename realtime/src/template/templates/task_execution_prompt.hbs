{
  "system_instruction": {
      "parts": [
        {
          "text": "{{system_prompt}}"
        }
      ]
   },
  "contents": [
    {{#each conversation_history}}
    {
      "role": "{{this.role}}",
      "parts": [
        {
          "text": "{{this.content}}"
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  "generationConfig": {
    "thinkingConfig": {
      "thinkingBudget": 512
    },
    "responseMimeType": "application/json",
    "responseSchema": {
      "type": "OBJECT",
      "properties": {
        "task_execution": {
          "type": "OBJECT",
          "properties": {
            "approach": {
              "type": "STRING",
              "description": "How you plan to execute this specific task"
            },
            "actions": {
              "type": "OBJECT",
              "properties": {
                "action": {
                  "type": "ARRAY",
                  "items": {
                    "type": "OBJECT",
                    "properties": {
                      "type": {
                        "type": "STRING",
                        "enum": ["tool_call", "workflow_call", "knowledge_search", "context_search"],
                        "description": "Type of action matching the task type"
                      },
                      "details": {
                        "type": "OBJECT",
                        "description": "Action-specific details including parameters",
                        "properties": {
                          "resource_name": {
                            "type": "STRING",
                            "description": "Name of the tool/workflow/knowledge base to use"
                          },
                          "description": {
                            "type": "STRING",
                            "description": "Description of what this action will do"
                          },
                          "parameter_hints": {
                            "type": "STRING",
                            "description": "Hints about what parameters will be needed (not actual values)",
                            "nullable": true
                          }
                        },
                        "required": ["resource_name", "description"]
                      },
                      "purpose": {
                        "type": "STRING",
                        "description": "Why this action helps complete the task"
                      }
                    },
                    "required": ["type", "details", "purpose"]
                  }
                }
              },
              "required": ["action"]
            },
            "expected_result": {
              "type": "STRING",
              "description": "What result you expect from this execution"
            }
          },
          "required": ["approach", "actions", "expected_result"]
        },
        "execution_status": {
          "type": "STRING",
          "enum": ["ready", "blocked", "cannot_execute"],
          "description": "Whether the task can be executed now"
        },
        "blocking_reason": {
          "type": "STRING",
          "description": "If blocked or cannot execute, explain why",
          "nullable": true
        }
      },
      "required": ["task_execution", "execution_status"]
    },
    "temperature": 0.5,
    "maxOutputTokens": 4096
  }
}