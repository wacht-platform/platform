{{#if system_prompt}}
<System>
{{system_prompt}}
</System>
{{/if}}

<Request>
Please validate the search results and determine the next action.

Return your response as a JSON object with the following structure:
{
    "validation_result": "success|partial_success|needs_refinement|failed",
    "completeness_score": 0.0-1.0,
    "relevance_assessment": {
        "overall_relevance": 0.0-1.0,
        "key_findings": [
            "Important information found",
            "Relevant insight discovered"
        ],
        "missing_information": [
            "What's still needed",
            "Gaps in coverage"
        ],
        "confidence_level": "high|medium|low"
    },
    "content_gaps": [
        {
            "gap_type": "conceptual|detailed|example|explanation",
            "description": "What specifically is missing",
            "suggested_search_terms": ["new", "search", "terms"]
        }
    ],
    "loop_decision": "complete|refine_and_retry|try_alternative_strategy|abort_insufficient",
    "next_iteration_guidance": "Specific instructions for the next search iteration" or null
}
</Request>